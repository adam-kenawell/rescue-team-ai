# ── LLM Provider ──────────────────────────────────────────────────# LLM Provider: anthropic | openai | gemini

# Which provider to use for all agent calls.LLM_PROVIDER=anthropic

# Options: anthropic | openai | gemini

LLM_PROVIDER=anthropic# API Keys (set the one matching your LLM_PROVIDER)

ANTHROPIC_API_KEY=

# ── API Keys ──────────────────────────────────────────────────────OPENAI_API_KEY=

# Only the key matching your LLM_PROVIDER is required.GEMINI_API_KEY=

# The others can be left blank.

ANTHROPIC_API_KEY=# Django

OPENAI_API_KEY=DJANGO_SECRET_KEY=change-me-in-production

GEMINI_API_KEY=DJANGO_DEBUG=True

DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── Django ────────────────────────────────────────────────────────
# Secret key for Django's cryptographic signing. Generate a real one for production.
DJANGO_SECRET_KEY=change-me-in-production

# Enable debug mode (True for local dev, False for production)
DJANGO_DEBUG=True

# Comma-separated list of allowed hostnames
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
